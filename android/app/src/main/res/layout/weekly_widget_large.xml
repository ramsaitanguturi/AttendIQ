<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1F2B"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="AttendIQ"
            android:textColor="#6C5CE7"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_week_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Week 5"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2E3044"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp" />

    <!-- Days Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- MON -->
        <TextView
            android:id="@+id/tv_day_mon_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MON"
            android:textColor="#6C5CE7"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_day_mon_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OS 09:00  •  DBMS 11:00"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <!-- TUE -->
        <TextView
            android:id="@+id/tv_day_tue_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TUE"
            android:textColor="#6C5CE7"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_day_tue_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COA 10:00  •  Math 14:00"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <!-- WED -->
        <TextView
            android:id="@+id/tv_day_wed_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WED"
            android:textColor="#6C5CE7"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_day_wed_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No Classes"
            android:textColor="#A0A5BD"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <!-- THU -->
        <TextView
            android:id="@+id/tv_day_thu_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THU"
            android:textColor="#6C5CE7"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_day_thu_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CN 09:00  •  OS Lab 14:00"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <!-- FRI -->
        <TextView
            android:id="@+id/tv_day_fri_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FRI"
            android:textColor="#6C5CE7"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_day_fri_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Project 10:00"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
