<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1F2B"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="AttendIQ"
            android:textColor="#6C5CE7"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_month_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="July 2026"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2E3044"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp" />

    <!-- Date Strip Row -->
    <LinearLayout
        android:id="@+id/layout_date_strip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_day_1"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="20"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_day_2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="21"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_day_3"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="22"
            android:textColor="#EF5350"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_day_4"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="23"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_day_5"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="24"
            android:textColor="#FFCA28"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upcoming:"
        android:textColor="#6C5CE7"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Upcoming List -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_upcoming_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="22 July  •  OS Project Submission"
            android:textColor="#FF9800"
            android:textSize="12sp"
            android:paddingVertical="2dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_upcoming_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="25 July  •  Mid Semester Exam"
            android:textColor="#EF5350"
            android:textSize="12sp"
            android:paddingVertical="2dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_upcoming_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="28 July  •  College Foundation Day"
            android:textColor="#AB47BC"
            android:textSize="12sp"
            android:paddingVertical="2dp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
